APP_NAME=propokertv-api
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

DB_HOST=localhost
DB_PORT=55436
DB_NAME=propokertv
DB_USERNAME=propokertv
DB_PASSWORD=propokertv

JWT_ISSUER=propokertv
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30
JWT_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
JWT_EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
JWT_SECRET=replace-with-very-long-random-secret

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./var/storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

ACTUATOR_EXPOSE=health,info,metrics,prometheus
